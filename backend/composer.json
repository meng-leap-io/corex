{
    "name": "corex/platform",
    "description": "Corex.dev - Multi-domain AI-powered development platform",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^11.0",
        "firebase/php-jwt": "^6.10",
        "predis/predis": "^2.2",
        "laravel/sanctum": "^4.0",
        "nativephp/electron": "^0.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.16",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
        "App\\": "app/",
        "Database\\Factories\\": "database/factories/",
        "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\\\Foundation\\\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "format": "vendor/bin/pint",
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "audit": {
            "ignore": [
                "PKSA-m5cs-t1y6-qpcs",
                "PKSA-3r5d-mb8f-1qw9",
                "PKSA-mdq4-51ck-6kdq",
                "PKSA-8qx3-n5y5-vvnd",
                "PKSA-q46n-4fdk-zjr4",
                "PKSA-qzrn-rnz3-85w1",
                "PKSA-w7xr-vk7n-rstm",
                "PKSA-y2cr-5h3j-g3ys"
            ]
        }
    }
}
