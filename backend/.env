# Corex.dev Environment Variables - Windows Desktop Version

# Application Settings
APP_NAME=Corex
APP_ENV=local
APP_DEBUG=true
APP_ADMIN_EMAIL=admin@corex.dev
APP_URL=http://localhost:8000
APP_STORAGE_PATH=%APPDATA%\\Corex\\storage
APP_PUBLIC_PATH=%APPDATA%\\Corex\\public
APP_RUNTIME=production

# Database (Local SQLite for offline use)
DB_CONNECTION=sqlite
DB_DATABASE=%APPDATA%\\Corex\\database\\corex.sqlite
DB_FOREIGN_KEYS=false
DB_ENGINE=sqlite

# Cache & Session
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis (Windows Local)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_CLIENT=phpredis
REDIS_ASYNC_FLUSH=true
REDIS_OPTIONS.serialize_keys=false

# JWT Authentication
JWT_SECRET=test-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_PUBLIC_KEY=""
JWT_PRIVATE_KEY=""
JWT_TTL=10080
JWT_REFRESH_TTL=20160

# AI Gateway
AI_GATEWAY_URL=http://localhost:8001
AI_GATEWAY_API_KEY=

# Supabase (Online Database + Auth)
SUPABASE_URL=https://iprhzagvffgpfihrmeqd.supabase.co
SUPABASE_KEY=sb_publishable_DBnWTqXK0l2LhAVtYMenXg_2JhBx
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_KEY=

# Google OAuth (configure in Supabase Dashboard > Authentication > Providers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session & Remember Me
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SUPABASE_REMEMBER_DAYS=30
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_DATABASE=postgres
SUPABASE_DB_USERNAME=iprhzagvffgpfihrmeqd
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require
SUPABASE_STORAGE_BUCKET=app-files
SUPABASE_REALTIME_ENABLED=true
SUPABASE_AUTO_CONFIRM=false
SUPABASE_REDIRECT_URL=http://localhost:8000/auth/callback
SUPABASE_AUTO_SYNC=true
SUPABASE_SYNC_INTERVAL=30

# Sanctum
SANCTUM_STATEFUL_DOMAINS=corex.dev,console.corex.dev,localhost,localhost:3000,localhost:8000,127.0.0.1
SANCTUM_TOKEN_PREFIX=corex_

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_PATH=%APPDATA%\\Corex\\storage\\logs

# Frontend
FRONTEND_URL=https://console.corex.dev

# Security
CORS_ALLOWED_ORIGINS=https://corex.dev,https://console.corex.dev

# Windows Paths Configuration
WINDOWS_APP_DATA_PATH=%APPDATA%\\Corex
WINDOWS_CACHE_DIR=%WINDOWS_APP_DATA_PATH%\\cache
WINDOWS_STORAGE_DIR=%WINDOWS_APP_DATA_PATH%\\storage
WINDOWS_QUEUE_DIR=%WINDOWS_APP_DATA_PATH%\\queues

# Performance Settings for Desktop
APP_MAINTENANCE_ALLOW_EDITING=true
STORAGE_DISK_LOCAL=public
STORAGE_DISK_PUBLIC=public
STORAGE_DISK_CACHE=redis
STORAGE_DISK_QUEUE=redis

# Mobile/Offline Settings
AUTH_ENABLE_MOBILE_SUPPORT=true
CACHE_ENABLE_MEMORY_CACHE=true
CACHE_LOCAL_STORAGE_PATH=%WINDOWS_STORAGE_DIR%\\local_cache
CACHE_MAX_LOCAL_MB=100

# AI Gateway Configuration
AI_GATEWAY_ENABLE_OFFLINE_MODE=true
AI_GATEWAY_OFFLINE_MAX_TOKENS=100000

# Backup Settings
DB_BACKUP_ENABLED=true
DB_BACKUP_PATH=%WINDOWS_STORAGE_DIR%\\backups
DB_BACKUP_RETENTION_DAYS=30
