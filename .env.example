# Corex.dev Environment Variables

# Application Settings
APP_NAME=Corex
APP_ENV=production
APP_KEY=
APP_URL=https://corex.dev
APP_DEBUG=false

# Database (Supabase)
DB_CONNECTION=pgsql
DB_HOST=db.supabase.co
DB_PORT=5432
DB_DATABASE=corex
DB_USERNAME=postgres
DB_PASSWORD=

# Cache & Session
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY=""
JWT_PRIVATE_KEY=""

# AI Gateway
AI_GATEWAY_URL=http://ai-gateway:8000
AI_GATEWAY_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error

# Frontend
FRONTEND_URL=https://console.corex.dev

# Security
CORS_ALLOWED_ORIGINS=https://corex.dev,https://console.corex.dev