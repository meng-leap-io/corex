# Corex.dev Environment Variables

# Application Settings
APP_NAME=Corex
APP_ENV=production
APP_KEY=base64:G5OpziTESaUmA5vChGUod6zt41icX9tPEQeRnYPfJjQ=
APP_URL=https://corex.dev
APP_DEBUG=false
APP_ADMIN_EMAIL=admin@corex.dev

# Database (Supabase)
DB_CONNECTION=pgsql
DB_HOST=db.supabase.co
DB_PORT=5432
DB_DATABASE=corex
DB_USERNAME=postgres
DB_PASSWORD=

# Cache & Session
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY=""
JWT_PRIVATE_KEY=""
JWT_TTL=10080
JWT_REFRESH_TTL=20160

# AI Gateway
AI_GATEWAY_URL=http://ai-gateway:8000
AI_GATEWAY_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

# Sanctum
SANCTUM_STATEFUL_DOMAINS=corex.dev,console.corex.dev,localhost,localhost:3000,localhost:8000
SANCTUM_TOKEN_PREFIX=corex_

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error

# Frontend
FRONTEND_URL=https://console.corex.dev

# Security
CORS_ALLOWED_ORIGINS=https://corex.dev,https://console.corex.dev

# ---------------------------------------------------------------------------
# Sentry Error Tracking
# ---------------------------------------------------------------------------
SENTRY_LARAVEL_DSN=https://public:private@sentry.corex.dev/1
SENTRY_DSN=https://public:private@sentry.corex.dev/1
SENTRY_FRONTEND_DSN=https://public:private@sentry.corex.dev/2
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.25
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_PII=false
SENTRY_BREADCRUMBS_SQL=true
SENTRY_BREADCRUMBS_SQL_BINDINGS=false
SENTRY_BREADCRUMBS_QUEUE=true
SENTRY_BREADCRUMBS_COMMANDS=true
SENTRY_BREADCRUMBS_HTTP=true
SENTRY_BREADCRUMBS_LOGS=true
SENTRY_BREADCRUMBS_CACHE=true
SENTRY_BREADCRUMBS_REDIS=true

# ---------------------------------------------------------------------------
# Prometheus / OpenTelemetry
# ---------------------------------------------------------------------------
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
OTEL_SERVICE_NAME=corex-ai-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.25

# ---------------------------------------------------------------------------
# Grafana / Loki
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
PROMETHEUS_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Alerting
# ---------------------------------------------------------------------------
SLACK_WEBHOOK=https://hooks.slack.com/services/T00/B00/xxxx
PAGERDUTY_ROUTING_KEY=

# ---------------------------------------------------------------------------
# Health Checks
# ---------------------------------------------------------------------------
HEALTH_CHECK_REDIS_ENABLED=true
HEALTH_CHECK_DATABASE_ENABLED=false
