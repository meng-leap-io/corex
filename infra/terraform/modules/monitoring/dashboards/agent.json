{
  "title": "Corex Agent System",
  "uid": "corex-agent",
  "version": 1,
  "tags": ["corex", "agents"],
  "timezone": "browser",
  "panels": [
    {
      "title": "Agent Requests by Type",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "rate(agent_requests_total{environment=\"${environment}\"}[5m])", "legendFormat": "{{agent}}"}]
    },
    {
      "title": "Agent Request Duration",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(agent_request_duration_seconds_bucket[5m])) by (le, agent))", "legendFormat": "{{agent}}"}]
    },
    {
      "title": "Agent Errors",
      "type": "graph",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "targets": [{"expr": "rate(agent_errors_total{environment=\"${environment}\"}[5m])", "legendFormat": "{{agent}}"}]
    },
    {
      "title": "Token Consumption by Agent",
      "type": "graph",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "targets": [{"expr": "rate(agent_tokens_total{environment=\"${environment}\"}[5m])", "legendFormat": "{{agent}}"}]
    },
    {
      "title": "Active Workflows",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "targets": [{"expr": "sum(agent_active_workflows{environment=\"${environment}\"})", "legendFormat": "active"}]
    }
  ]
}
