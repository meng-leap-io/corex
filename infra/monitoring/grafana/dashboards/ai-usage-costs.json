{
  "__inputs": [],
  "__requires": [
    {"type": "datasource", "id": "prometheus", "name": "Prometheus"}
  ],
  "title": "AI Usage & Costs",
  "uid": "corex-ai-usage-costs",
  "tags": ["corex", "ai", "costs"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": false,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "templating": {
    "list": [
      {"type": "interval", "name": "interval", "query": "30s,1m,5m,15m,30m,1h", "current": {"text": "5m", "value": "5m"}, "refresh": 2},
      {"type": "datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "current": {"text": "Prometheus", "value": "prometheus"}},
      {"type": "query", "name": "provider", "query": "label_values(ai_requests_total, provider)", "refresh": 1, "includeAll": true, "allValue": ".*", "multi": true},
      {"type": "query", "name": "model", "query": "label_values(ai_requests_total, model)", "refresh": 1, "includeAll": true, "allValue": ".*", "multi": true}
    ]
  },
  "panels": [
    {
      "title": "Daily Cost (USD)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 6},
      "targets": [
        {
          "expr": "max(ai_daily_cost_usd)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 100}
            ]
          }
        }
      }
    },
    {
      "title": "Total Requests Today",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 6},
      "targets": [
        {
          "expr": "sum(increase(ai_requests_total[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "blue"}
        }
      }
    },
    {
      "title": "Total Tokens Today",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 6},
      "targets": [
        {
          "expr": "sum(increase(ai_tokens_total[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "purple"}
        }
      }
    },
    {
      "title": "Avg Cost per Request",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 6},
      "targets": [
        {
          "expr": "max(ai_daily_cost_usd) / sum(increase(ai_requests_total[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "fixed", "fixedColor": "orange"}
        }
      }
    },
    {
      "title": "Active Users Today",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 6},
      "targets": [
        {
          "expr": "count(ai_user_tokens_total offset 24h > 0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "green"}
        }
      }
    },
    {
      "title": "Budget Remaining",
      "type": "gauge",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 6},
      "targets": [
        {
          "expr": "100 - (ai_daily_cost_usd / ai_daily_budget_usd * 100)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 20}
            ]
          }
        }
      }
    },
    {
      "title": "Cost by Provider",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(increase(ai_provider_cost_usd_total{provider=~\"$provider\"}[$interval])) by (provider)",
          "legendFormat": "{{ provider }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "title": "Request Rate by Provider",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(ai_requests_total{provider=~\"$provider\", model=~\"$model\"}[$interval])) by (provider, model)",
          "legendFormat": "{{ provider }} - {{ model }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Token Usage by Model",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(ai_tokens_total{model=~\"$model\"}[$interval])) by (model, type)",
          "legendFormat": "{{ model }} - {{ type }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens"
        }
      }
    },
    {
      "title": "Latency by Provider",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(ai_request_duration_seconds_sum{provider=~\"$provider\"}[$interval]) / rate(ai_request_duration_seconds_count{provider=~\"$provider\"}[$interval])",
          "legendFormat": "avg {{ provider }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Cost Breakdown by Model (24h)",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 22, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum(increase(ai_provider_cost_usd_total{provider=~\"$provider\"}[24h])) by (model)",
          "legendFormat": "{{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Top Users by Cost (24h)",
      "type": "table",
      "gridPos": {"x": 8, "y": 22, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum(increase(ai_user_cost_usd_total[24h])) by (user_id))",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {"align": "left"}
        }
      },
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {}, "indexByName": {}, "renameByName": {"user_id": "User ID", "Value #A": "Cost (24h)"}}}
      ]
    },
    {
      "title": "Error Rate by Provider",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 22, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(ai_request_failures_total{provider=~\"$provider\"}[$interval])) by (provider) / sum(rate(ai_requests_total{provider=~\"$provider\"}[$interval])) by (provider) * 100",
          "legendFormat": "{{ provider }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0
        }
      }
    },
    {
      "title": "Cache Performance",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 30, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(ai_cache_hits_total[$interval])",
          "legendFormat": "hits"
        },
        {
          "expr": "rate(ai_cache_misses_total[$interval])",
          "legendFormat": "misses"
        },
        {
          "expr": "rate(ai_cache_hits_total[$interval]) / (rate(ai_cache_hits_total[$interval]) + rate(ai_cache_misses_total[$interval])) * 100",
          "legendFormat": "hit rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "Provider Failures (24h)",
      "type": "table",
      "gridPos": {"x": 12, "y": 30, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(increase(ai_request_failures_total{provider=~\"$provider\"}[24h])) by (provider, error_type)",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "left"}
        }
      },
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {}, "indexByName": {}, "renameByName": {"provider": "Provider", "error_type": "Error Type", "Value #A": "Count"}}}
      ]
    }
  ]
}
