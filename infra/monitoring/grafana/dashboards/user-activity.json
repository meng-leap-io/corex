{
  "__inputs": [],
  "__requires": [
    {"type": "datasource", "id": "prometheus", "name": "Prometheus"}
  ],
  "title": "User Activity",
  "uid": "corex-user-activity",
  "tags": ["corex", "users", "analytics"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": false,
  "refresh": "1m",
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {"type": "interval", "name": "interval", "query": "5m,15m,30m,1h,6h,24h", "current": {"text": "1h", "value": "1h"}, "refresh": 2},
      {"type": "datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "current": {"text": "Prometheus", "value": "prometheus"}}
    ]
  },
  "panels": [
    {
      "title": "Daily Active Users",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 5},
      "targets": [
        {"expr": "corex:dau:count"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "green"}
        }
      }
    },
    {
      "title": "Monthly Active Users",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 5},
      "targets": [
        {"expr": "corex:mau:count"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "blue"}
        }
      }
    },
    {
      "title": "New Users (24h)",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 5},
      "targets": [
        {"expr": "sum(increase(corex_user_registrations_total[24h]))"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "purple"}
        }
      }
    },
    {
      "title": "Total Registered Users",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 5},
      "targets": [
        {"expr": "corex_total_users"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "orange"}
        }
      }
    },
    {
      "title": "DAU/MAU Ratio",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 5},
      "targets": [
        {"expr": "corex:dau:count / corex:mau:count * 100"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "green", "value": 20}
            ]
          }
        }
      }
    },
    {
      "title": "New User Registrations",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(corex_user_registrations_total[$interval])",
          "legendFormat": "registrations",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "Active User Sessions",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "corex_active_sessions",
          "legendFormat": "sessions",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "title": "User Engagement by Feature",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 13, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(corex_feature_usage_total[$interval])) by (feature)",
          "legendFormat": "{{ feature }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "User Retention (Cohort)",
      "type": "table",
      "gridPos": {"x": 12, "y": 13, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "corex_user_retention_rate",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"align": "center"}
        }
      },
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {}, "indexByName": {}, "renameByName": {"cohort": "Cohort", "week_1": "Week 1", "week_2": "Week 2", "week_4": "Week 4", "week_8": "Week 8"}}}
      ]
    },
    {
      "title": "Geographic Distribution",
      "type": "geomap",
      "gridPos": {"x": 0, "y": 21, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(corex_user_geo_country) by (country)",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "User Plan Distribution",
      "type": "piechart",
      "gridPos": {"x": 12, "y": 21, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "corex_users_by_plan",
          "legendFormat": "{{ plan }}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Top Users by Feature Usage",
      "type": "table",
      "gridPos": {"x": 18, "y": 21, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum(increase(corex_feature_usage_total[7d])) by (user_id))",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "left"}
        }
      },
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {}, "indexByName": {}, "renameByName": {"user_id": "User ID", "Value #A": "Total Actions (7d)"}}}
      ]
    }
  ]
}
