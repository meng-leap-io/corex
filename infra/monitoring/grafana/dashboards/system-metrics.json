{
  "__inputs": [],
  "__requires": [
    {"type": "datasource", "id": "prometheus", "name": "Prometheus"}
  ],
  "title": "System Metrics",
  "uid": "corex-system-metrics",
  "tags": ["corex", "infrastructure"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": false,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "templating": {
    "list": [
      {"type": "interval", "name": "interval", "query": "30s,1m,5m,15m,30m,1h", "current": {"text": "1m", "value": "1m"}, "refresh": 2},
      {"type": "datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "current": {"text": "Prometheus", "value": "prometheus"}}
    ]
  },
  "panels": [
    {
      "title": "CPU Utilization",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$interval])) by (instance) * 100)",
          "legendFormat": "{{ instance }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Memory Utilization",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{ instance }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total[5m])",
          "legendFormat": "rx {{ device }}",
          "interval": "$interval"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total[5m])",
          "legendFormat": "tx {{ device }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "read {{ device }}",
          "interval": "$interval"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "write {{ device }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "title": "Docker Containers",
      "type": "stat",
      "gridPos": {"x": 0, "y": 16, "w": 4, "h": 6},
      "targets": [
        {
          "expr": "count(container_last_seen)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "fixed", "fixedColor": "green"}
        }
      }
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": {"x": 4, "y": 16, "w": 10, "h": 6},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[$interval])) by (job)",
          "legendFormat": "{{ job }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Active Services",
      "type": "stat",
      "gridPos": {"x": 14, "y": 16, "w": 4, "h": 6},
      "targets": [
        {
          "expr": "count(up == 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "fixed", "fixedColor": "green"}
        }
      }
    },
    {
      "title": "Services Down",
      "type": "stat",
      "gridPos": {"x": 18, "y": 16, "w": 6, "h": 6},
      "targets": [
        {
          "expr": "count(up == 0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "fixed", "fixedColor": "red"}
        }
      }
    },
    {
      "title": "TCP Connections",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 22, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "node_netstat_Tcp_CurrEstab",
          "legendFormat": "established"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "Load Average",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 22, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "1m"
        },
        {
          "expr": "node_load5",
          "legendFormat": "5m"
        },
        {
          "expr": "node_load15",
          "legendFormat": "15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "System Uptime",
      "type": "stat",
      "gridPos": {"x": 16, "y": 22, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "fixed", "fixedColor": "green"}
        }
      }
    }
  ]
}
