{
  "__inputs": [],
  "__requires": [
    {"type": "datasource", "id": "prometheus", "name": "Prometheus"},
    {"type": "datasource", "id": "loki", "name": "Loki"}
  ],
  "title": "Error Rates & Logs",
  "uid": "corex-error-rates",
  "tags": ["corex", "errors", "logs"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": false,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {"type": "interval", "name": "interval", "query": "30s,1m,5m,15m,30m,1h", "current": {"text": "1m", "value": "1m"}, "refresh": 2},
      {"type": "datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "current": {"text": "Prometheus", "value": "prometheus"}},
      {"type": "datasource", "name": "DS_LOKI", "query": "loki", "current": {"text": "Loki", "value": "loki"}},
      {"type": "query", "name": "service", "query": "label_values(up, job)", "refresh": 1, "includeAll": true, "allValue": ".*", "multi": true}
    ]
  },
  "panels": [
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "job:error_rate:ratio5m{job=~\"$service\"} * 100",
          "legendFormat": "{{ job }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "title": "Error Count by Status Code",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\", status=~\"4..|5..\"}[$interval])) by (status)",
          "legendFormat": "HTTP {{ status }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "eps"
        }
      }
    },
    {
      "title": "Error Distribution (Last 3h)",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=~\"$service\", status=~\"5..\"}[3h])) by (status)",
          "legendFormat": "HTTP {{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Log Error Rate by Level",
      "type": "logs",
      "gridPos": {"x": 6, "y": 8, "w": 18, "h": 8},
      "targets": [
        {
          "expr": "{job=~\"$service\"} |= \"error\" |= \"ERROR\" |= \"critical\"",
          "legendFormat": "",
          "maxLines": 50
        }
      ],
      "datasource": {"type": "loki", "uid": "loki"}
    },
    {
      "title": "4xx Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\", status=~\"4..\"}[$interval])) by (path)",
          "legendFormat": "{{ path }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "eps"
        }
      }
    },
    {
      "title": "Slowest Failing Endpoints",
      "type": "table",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "topk(20, sum(rate(http_requests_total{job=~\"$service\", status=~\"5..\"}[$interval])) by (path))",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "eps",
          "custom": {"align": "left"}
        }
      },
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {}, "indexByName": {}, "renameByName": {"path": "Endpoint", "Value #A": "Error Rate (eps)"}}}
      ]
    },
    {
      "title": "Recent Alerts",
      "type": "alertlist",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "options": {
        "alertName": "",
        "dashboardTitle": "",
        "folderId": null,
        "stateFilter": {"alerting": true, "firing": true, "pending": true, "noData": true, "ok": false, "paused": false},
        "maxItems": 20
      }
    },
    {
      "title": "Log Errors by Service (Realtime)",
      "type": "logs",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "{job=~\"$service\"} |= \"error\"",
          "legendFormat": "",
          "maxLines": 100
        }
      ],
      "datasource": {"type": "loki", "uid": "loki"}
    }
  ]
}
