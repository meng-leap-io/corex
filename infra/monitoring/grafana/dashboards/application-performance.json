{
  "__inputs": [],
  "__requires": [
    {"type": "datasource", "id": "prometheus", "name": "Prometheus"}
  ],
  "title": "Application Performance",
  "uid": "corex-app-performance",
  "tags": ["corex", "application"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": false,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "templating": {
    "list": [
      {"type": "interval", "name": "interval", "query": "30s,1m,5m,15m,30m,1h", "current": {"text": "1m", "value": "1m"}, "refresh": 2},
      {"type": "datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "current": {"text": "Prometheus", "value": "prometheus"}},
      {"type": "query", "name": "service", "query": "label_values(up, job)", "refresh": 1, "includeAll": true, "allValue": ".*", "multi": true}
    ]
  },
  "panels": [
    {
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\"}[$interval])) by (job, method)",
          "legendFormat": "{{ job }} - {{ method }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\", status=~\"5..\"}[$interval])) by (job) / sum(rate(http_requests_total{job=~\"$service\"}[$interval])) by (job) * 100",
          "legendFormat": "{{ job }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "title": "P95 / P99 Latency",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\"}[$interval])) by (le, job))",
          "legendFormat": "p95 {{ job }}",
          "interval": "$interval"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\"}[$interval])) by (le, job))",
          "legendFormat": "p99 {{ job }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      }
    },
    {
      "title": "Average Latency",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum{job=~\"$service\"}[$interval]) / rate(http_request_duration_seconds_count{job=~\"$service\"}[$interval])",
          "legendFormat": "avg {{ job }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "HTTP Status Code Distribution",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\"}[$interval])) by (status)",
          "legendFormat": "{{ status }}",
          "interval": "$interval"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Slowest Endpoints (p95 > 1s)",
      "type": "table",
      "gridPos": {"x": 8, "y": 16, "w": 16, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\"}[$interval])) by (le, path))",
          "legendFormat": "{{ path }}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        }
      },
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {}, "indexByName": {}, "renameByName": {"Value #A": "p95 Latency (s)", "path": "Endpoint"}}}
      ]
    },
    {
      "title": "Database Query Performance",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched[5m])",
          "legendFormat": "fetched - {{ db }}"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted[5m])",
          "legendFormat": "inserted - {{ db }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "Cache Performance",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[$interval])",
          "legendFormat": "hits"
        },
        {
          "expr": "rate(redis_keyspace_misses_total[$interval])",
          "legendFormat": "misses"
        },
        {
          "expr": "rate(redis_keyspace_hits_total[$interval]) / (rate(redis_keyspace_hits_total[$interval]) + rate(redis_keyspace_misses_total[$interval])) * 100",
          "legendFormat": "hit rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      }
    },
    {
      "title": "Active Database Connections",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 32, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "pg_stat_database_numbackends",
          "legendFormat": "{{ db }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "Queue Worker Status",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 32, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "laravel_queue_size",
          "legendFormat": "{{ queue }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "Scheduler Health",
      "type": "stat",
      "gridPos": {"x": 16, "y": 32, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "laravel_scheduler_last_run_seconds_ago"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 120},
              {"color": "red", "value": 300}
            ]
          }
        }
      }
    }
  ]
}
